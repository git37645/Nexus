# ============================================================
# Alexandria Backend — Environment Variables
# Copy this to .env and fill in all values.
# NEVER commit .env to git.
# ============================================================

NODE_ENV=production
PORT=4000
BACKEND_URL=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app

# PostgreSQL — get this from Neon dashboard
DATABASE_URL=

# JWT Secrets — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# SMTP — use Brevo (free: 300 emails/day)
# Sign up at https://www.brevo.com → Transactional → SMTP & API
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=
EMAIL_FROM_NAME=Alexandria University Platform

# File Storage
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=25

# Security
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 2FA
TOTP_ISSUER=Alexandria University

# First-admin setup — password is set via /setup-admin link, never hardcoded
ADMIN_EMAIL=ivanknyaze@gmail.com
ADMIN_USERNAME=ivan_admin
