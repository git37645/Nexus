# ============================================================
# Nexus Backend — Environment Variables
# Copy this file to .env and fill in all values.
# NEVER commit .env to git.
# ============================================================

# Application
NODE_ENV=production
PORT=4000
APP_URL=https://your-backend.onrender.com
FRONTEND_URL=https://your-frontend.vercel.app

# PostgreSQL — get this from Neon / Supabase / Railway / Render
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/nexus_db?schema=public"

# JWT Secrets
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# Use a DIFFERENT value for each secret.
JWT_ACCESS_SECRET=REPLACE_WITH_64_BYTE_HEX_SECRET
JWT_REFRESH_SECRET=REPLACE_WITH_DIFFERENT_64_BYTE_HEX_SECRET
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=30d

# Email (SMTP)
# For free SMTP: use Brevo (formerly Sendinblue) or Mailjet free tier.
# Both offer 300 free emails/day with no credit card required.
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-login@example.com
SMTP_PASS=your-smtp-password
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=Nexus University Platform

# File Storage (local disk — files are lost on redeploy in cloud)
# In production, consider using S3-compatible storage instead.
STORAGE_PATH=./storage
MAX_FILE_SIZE_MB=25
ALLOWED_IMAGE_TYPES=image/jpeg,image/png,image/gif,image/webp
ALLOWED_DOCUMENT_TYPES=application/pdf,application/msword,application/vnd.openxmlformats-officedocument.wordprocessingml.document,application/vnd.ms-powerpoint,application/vnd.openxmlformats-officedocument.presentationml.presentation,text/plain

# Rate Limiting
LOGIN_ATTEMPT_LIMIT=5
LOGIN_LOCKOUT_MINUTES=15
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# 2FA (TOTP)
TOTP_ISSUER=Nexus University

# First-admin account
# Set these before running: npm run db:seed
# The seed generates a one-time setup link — check your server logs after seeding.
# The admin sets their own password via /setup-admin?token=...
# admin/admin does NOT exist in this project.
ADMIN_EMAIL=ivanknyaze@gmail.com
ADMIN_USERNAME=ivan_admin

# Optional: S3-compatible storage (comment out local STORAGE_PATH above if using this)
# S3_ENDPOINT=https://s3.amazonaws.com
# S3_REGION=eu-central-1
# S3_BUCKET=nexus-uploads
# S3_ACCESS_KEY=
# S3_SECRET_KEY=
