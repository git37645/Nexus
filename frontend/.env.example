# ============================================================
# Nexus Frontend — Environment Variables
# Copy this file to .env and fill in your values.
# In development, you do NOT need VITE_API_URL — the Vite proxy handles it.
# In production (Vercel), set VITE_API_URL to your backend URL.
# ============================================================

# Backend URL for production (no trailing slash)
# Example: https://nexus-backend.onrender.com
VITE_API_URL=

# Default UI language: uk | sk | en
VITE_DEFAULT_LANGUAGE=uk
